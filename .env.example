# ============================================
# ETH Crypto Prediction System
# 环境变量配置文件
# 复制此文件为 .env 并填入你的API密钥
# ============================================

# === Binance API ===
# 注册地址: https://www.binance.com/
# API管理: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# === OKX API ===
# 注册地址: https://www.okx.com/
# API管理: https://www.okx.com/account/my-api
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

# === Coinbase API ===
# 注册地址: https://www.coinbase.com/
# API管理: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# === Go Collector 设置 ===
COLLECTOR_PORT=8080
COLLECTOR_API_URL=http://localhost:8080

# === 数据目录 ===
DATA_DIR=./data
MODEL_DIR=./models

# === 阶段控制（Stage + Feature Flags）===
# 详细说明见 docs/STAGES_FLAGS_CN.md
#
# STAGE 控制默认开启的能力集合：
#   S0 = 研究验证期（仅开启报告类工具）
#   S1 = 生产候选（推荐默认）：报告 + model registry + 多周期特征
#   S2 = 可运维：在 S1 基础上增加 drift/calibration 监控
#   S3 = 准实盘：在 S2 基础上增加永续风控守卫
#   S4 = 平台化：在 S3 基础上增加自动重训与自动晋升/回滚
STAGE=S1

# 单项覆盖（一般不需要，只用于调试或灰度）：
# ENABLE_THRESHOLD_GRID_REPORT=true
# ENABLE_DAILY_EVAL_REPORT=true
# ENABLE_MODEL_REGISTRY=true
# ENABLE_MTF_FEATURES=true
# ENABLE_DRIFT_MONITOR=false
# ENABLE_CALIBRATION_REPORT=false
# ENABLE_PERP_RISK_GUARDS=false
# ENABLE_SCHEDULED_RETRAIN=false
# ENABLE_PROMOTE_ROLLBACK_AUTOMATION=false
# ENABLE_EXOGENOUS_FEATURES=false

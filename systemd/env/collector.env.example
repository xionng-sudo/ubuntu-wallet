# Exchange API keys (DO NOT COMMIT real keys)
# Fill and copy to: /etc/ubuntu-wallet/collector.env
#
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
#
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSPHRASE=

# Service config
COLLECTOR_PORT=8080
COLLECT_INTERVAL=60s

# ML service endpoint (local)
ML_SERVICE_URL=http://127.0.0.1:9000/predict

# ─────────────────────────────────────────────────────────────────────────────
# Multi-symbol kline collection
# ─────────────────────────────────────────────────────────────────────────────
#
# SYMBOLS – comma-separated list of Binance USDT-margined symbols to collect.
#
#   Phase 1 (default, if SYMBOLS is unset):
#     BTCUSDT, ETHUSDT, SOLUSDT, BNBUSDT
#
#   Phase 2 (add to Phase 1, or set ENABLE_PHASE2_SYMBOLS=true):
#     XRPUSDT, DOGEUSDT, ADAUSDT
#
# Examples:
#   Phase 1 only (default – no need to set anything):
#     # SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
#
#   All 7 symbols via SYMBOLS:
#     SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT
#
#   All 7 symbols via flag:
#     ENABLE_PHASE2_SYMBOLS=true
#
# SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
# ENABLE_PHASE2_SYMBOLS=false

# ─────────────────────────────────────────────────────────────────────────────
# Primary symbol
# ─────────────────────────────────────────────────────────────────────────────
#
# PRIMARY_SYMBOL – the symbol used for:
#   • /api/market (current-price endpoint)
#   • root-level backward-compat files (data/klines_*.json)
#   • 1m/5m extra kline collection
#   • feature computation and ML signal generation
#   • health-check file freshness probe
#
# Resolution:
#   1. PRIMARY_SYMBOL env var – must also appear in SYMBOLS (startup error if not).
#   2. "ETHUSDT" if present in the enabled symbol list (backward-compatible default).
#   3. First symbol in SYMBOLS as a last-resort fallback.
#
# Leave unset to keep the default ETHUSDT behaviour (recommended for
# existing ETHUSDT-oriented deployments).
#
# PRIMARY_SYMBOL=ETHUSDT

# ─────────────────────────────────────────────────────────────────────────────
# Kline output paths
# ─────────────────────────────────────────────────────────────────────────────
#
# Each symbol's kline files land in:
#   $DATA_DIR/<SYMBOL>/klines_1h.json
#   $DATA_DIR/<SYMBOL>/klines_4h.json
#   $DATA_DIR/<SYMBOL>/klines_1d.json
#   (plus 15m for all symbols, and 1m/5m for the primary symbol only)
#
# DATA_DIR=/home/ubuntu/ubuntu-wallet/data

# ─────────────────────────────────────────────────────────────────────────────
# Backward-compatibility (legacy root-level klines_*.json)
# ─────────────────────────────────────────────────────────────────────────────
#
# When true (the default), the collector also writes klines_*.json directly
# under $DATA_DIR/.  These root-level files are a mirror of the PRIMARY_SYMBOL
# data (ETHUSDT by default), preserving the semantics that existing consumers
# relied on before multi-symbol support was added.
#
# ⚠  The root-level files always reflect PRIMARY_SYMBOL, NOT necessarily
#    BTCUSDT even though BTC appears first in the default SYMBOLS list.
#
# Set to false once all consumers have migrated to data/<SYMBOL>/klines_*.json.
#
# LEGACY_ETHUSDT_COMPAT=true


# ml-service environment variables example
# Copy to /etc/ubuntu-wallet/ml-service.env and adjust values.

# Root directory of the ubuntu-wallet repository on this server.
# Override here if your checkout is not at the default location.
APP_ROOT=/home/ubuntu/ubuntu-wallet

# ---------------------------------------------------------------------------
# Multi-symbol model directories
# ---------------------------------------------------------------------------
# Base directory under which per-symbol model subdirectories live.
# The service resolves each symbol's model from <MODELS_BASE_DIR>/<SYMBOL>/current.
# Example: BTCUSDT → models/BTCUSDT/current, ETHUSDT → models/ETHUSDT/current.
MODELS_BASE_DIR=/home/ubuntu/ubuntu-wallet/models

# Legacy single-model fallback directory.
# Used when a per-symbol directory does not yet exist for the requested symbol,
# or for deployments that have not yet migrated to per-symbol model artifacts.
# For a fully-migrated ETHUSDT deployment, set this to models/ETHUSDT/current.
MODEL_DIR=/home/ubuntu/ubuntu-wallet/models/ETHUSDT/current

# Data directory (base; per-symbol kline files live at DATA_DIR/<SYMBOL>/).
DATA_DIR=/home/ubuntu/ubuntu-wallet/data

# ---------------------------------------------------------------------------
# Prediction log routing
# ---------------------------------------------------------------------------
# Predictions are written to data/<SYMBOL>/predictions_log.jsonl by default.
# Set PREDICTIONS_LOG_ALSO_ROOT=1 to additionally write every prediction to the
# root-level data/predictions_log.jsonl (useful during migration to per-symbol logs).
# PREDICTIONS_LOG_ALSO_ROOT=0

# Override the root-level fallback log path (used when symbol is unknown or
# PREDICTIONS_LOG_ALSO_ROOT=1).
# PREDICTIONS_LOG_PATH=/home/ubuntu/ubuntu-wallet/data/predictions_log.jsonl

# ---------------------------------------------------------------------------
# ML thresholds
# ---------------------------------------------------------------------------
EVENT_V3_P_ENTER=0.65
EVENT_V3_DELTA=0.0

# ---------------------------------------------------------------------------
# Feature Flags
# All flags default to false (off). Enable opt-in after validation.
# ---------------------------------------------------------------------------
ENABLE_EXOG_FEATURES=false
ENABLE_DRIFT_MONITOR=false
ENABLE_CALIB_REPORT=false

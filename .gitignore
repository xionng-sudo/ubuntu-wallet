# .gitignore

# 环境
.env
venv/
__pycache__/
*.pyc
*.pyo

# 数据
data/
models/
!go-collector/models/
!go-collector/models/**/*.go
logs/
bin/

# Go
go-collector/go-collector
*.exe

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Temp
*.tmp
*.swp
# Python virtual environments
.venv/
venv310/
venv/
__pycache__/
*.pyc
# --- ops/runtime logs (local only) ---
check-go-collector.log
check-go-collector.log.*
*.gz
data/logs/*.log
data/logs/*.log.*
data/logs/*.jsonl
!data/logs/.gitkeep

# --- local ops scripts & backups (machine specific; may include secrets) ---
/check-go-collector.sh
/notify-telegram.sh
check-go-collector.sh.bak.*

# --- ensure nested venvs are ignored (important for ml-service/.venv) ---
**/.venv/
**/venv/
**/__pycache__/
/outputs/
